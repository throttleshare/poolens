# SplashLens app / PoolLens source repo
# Cloudflare Pages project: poolens

# Required in production. Set as a Cloudflare Pages secret.
ANTHROPIC_API_KEY=

# Recommended production marker. The scan function also treats app.splashlens.com
# and *.pages.dev as production hosts.
ENVIRONMENT=production

# Optional local-only development marker.
NODE_ENV=development

# Cloudflare bindings to configure in the Pages project, not plain env vars:
# - SCAN_USAGE_KV: KV namespace for monthly server-side scan metering.
# - SCAN_RATE_LIMITER: Cloudflare Rate Limiting binding for burst protection.
#
# Stripe/checkout configuration for paid scanner activation:
# - STRIPE_SECRET_KEY is a Cloudflare Pages secret. Required for Checkout
#   Session creation and /api/checkout-success entitlement issuance.
# - Price IDs can be overridden if the Stripe catalog changes.
STRIPE_SECRET_KEY=
SPLASHLENS_STRIPE_PRICE_MONTHLY=price_1TbAp725fqLun6cVz5lhOiiS
SPLASHLENS_STRIPE_PRICE_YEARLY=price_1TbAp825fqLun6cVoVG0wqQl
SPLASHLENS_APP_ORIGIN=https://app.splashlens.com
